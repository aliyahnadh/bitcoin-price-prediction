on = horizon\n\n        # Encoder\n        self.enc_lstm1 = layers.LSTM(lstm_units, return_sequences=True, name='enc_lstm1')\n        self.enc_drop  = CustomDropout(0.2, name='enc_drop')\n        self.enc_norm  = CustomLayerNorm(name='enc_norm')\n        self.enc_lstm2 = layers.LSTM(lstm_units, return_state=True, name='enc_lstm2')\n\n        # Decoder\n        self.dec_lstm  = layers.LSTM(lstm_units, return_sequences=True, name='dec_lstm')\n        self.dec_drop  = CustomDropout(0.2, name='dec_drop')\n        self.dec_mha   = CustomMultiHeadAttention(num_heads=4, key_dim=16, name='dec_mha')\n        self.dec_norm  = CustomLayerNorm(name='dec_norm')\n        self.dec_proj  = CustomDense(64, activation='relu', name='dec_proj')\n        self.dec_out   = CustomDense(1, activation='linear', name='dec_out')\n\n    def call(self, inputs, training=None):\n        enc_in, dec_in = inputs   # dec_in: (batch, horizon, 1)\n\n        # Encoder\n        x = self.enc_lstm1(enc_in, training=training)\n        x = self.enc_drop(x, training=training)\n        x = self.enc_norm(x)\n        _, h, c = self.enc_lstm2(x, training=training)\n\n        # Decoder\n        x    = self.dec_lstm(dec_in, initial_state=[h, c], training=training)\n        x    = self.dec_drop(x, training=training)\n        attn = self.dec_mha(x)\n        x    = self.dec_norm(x + attn)\n        x    = self.dec_proj(x)\n        x    = self.dec_out(x)          # (batch, horizon, 1)\n        return tf.squeeze(x, axis=-1)   # (batch, horizon)\n\nseq2seq = Seq2SeqLSTM(lstm_units=128, horizon=HORIZON, name='Seq2Seq_LSTM')\n\n# Build dengan dummy forward pass\n_de = tf.zeros((1, WINDOW_SIZE, N_FEATURES))\n_dd = tf.zeros((1, HORIZON, 1))\n_ = seq2seq((_de, _dd))\nseq2seq.summary()\nprint('Seq2Seq LSTM (Subclassing) siap')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T04:16:09.337514Z","iopub.execute_input":"2026-06-02T04:16:09.338055Z","iopub.status.idle":"2026-06-02T04:16:10.736216Z","shell.exec