np.float32)\n\nX_train, y_train = make_sequences(train_scaled, WINDOW_SIZE, HORIZON, TARGET_IDX)\nX_val,   y_val   = make_sequences(val_scaled,   WINDOW_SIZE, HORIZON, TARGET_IDX)\nX_test,  y_test  = make_sequences(test_scaled,  WINDOW_SIZE, HORIZON, TARGET_IDX)\n\nprint(f'X_train: {X_train.shape} | y_train: {y_train.shape}')\nprint(f'X_val  : {X_val.shape}   | y_val  : {y_val.shape}')\nprint(f'X_test : {X_test.shape}  | y_test : {y_test.shape}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T04:16:04.171075Z","iopub.execute_input":"2026-06-02T04:16:04.171416Z","iopub.status.idle":"2026-06-02T04:16:04.321088Z","shell.execute_reply.started":"2026-06-02T04:16:04.171379Z","shell.execute_reply":"2026-06-02T04:16:04.320043Z"}},"outputs":[{"name":"stdout","text":"X_train: (42449, 48, 10) | y_train: (42449, 24)\nX_val  : (5244, 48, 10)   | y_val  : (5244, 24)\nX_test : (5244, 48, 10)  | y_test : (5244, 24)\n","output_type":"stream"}],"execution_count":12},{"id":"c64c8c86-739f-41ab-962c-71d910f7e4c1","cell_type":"code","source":"# tf.data.Dataset Pipeline\nBATCH_SIZE = 64\nAUTOTUNE   = tf.data.AUTOTUNE\n\ndef make_tf_dataset(X, y, shuffle=False):\n    ds = tf.data.Dataset.from_tensor_slices((X, y))\n    if shuffle:\n        ds = ds.shuffle(buffer_size=len(X), seed=SEED)\n    return ds.batch(BATCH_SIZE).prefetch(AUTOTUNE)\n\ntrain_ds = make_tf_dataset(X_train, y_train, shuffle=True)\nval_ds   = make_tf_dataset(X_val,   y_val)\ntest_ds  = make_tf_dataset(X_test,  y_test)\n\nprint('tf.data.Dataset siap')\nfor bx, by in train_ds.take(1):\n    print(f'  Batch X: {bx.shape}  |  Batch y: {by.shape}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T04:16:04.322143Z","iopub.execute_input":"2026-06-02T04:16:04.322393Z","iopub.status.idle":"2026-06-02T04:16:08.154930Z","shell.execute_reply.started":"2026-06-02T04:16:04.322361Z","shell.execute_reply":"2026-06-02T04:16:08.153907Z"}},"outputs":[{"name":"stderr","text":"I0000 00:00:1780373765.968279      58 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 13757 MB memory:  -> device: 0, name: Tesla T4, pci bus id: 0000:00:04.0, compute capability: 7.5\nI0000 00:00:1780373765.974868      58 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:1 with 13757 MB memory:  -> device: 1, name: Tesla T4, pci bus id: 0000:00:05.0, compute capability: 7.5\n","output_type":"stream"},{"name":"stdout","text":"tf.data.Dataset siap\n  Batch X: (64, 48, 10)  |  Batch y: (64, 24)\n","output_type":"stream"}],"execution_count":13},{"id":"8b8aecd8-2679-4919-ac38-9191c8dae713","cell_type":"markdown","source":"## 7. Custom Layers","metadata":{}},{"id":"a86c7145-99f3-43e3-9b87-67388cfaf3b1","cell_type":"markdown","source":"* `CustomDense` — reimplementasi Dense layer dari nol.\n* `CustomMultiHeadAttention` — reimplementasi Multi-Head Attention dari nol (scaled dot-product).\n* `CustomDropout` & `CustomLayerNorm` — custom layer tambahan dari nol.","metadata":{}},{"id":"90d62b45-3746-49ea-8cb7-9e53d7bc9067","cell_type":"code","source":"# Custom Layer 1 : Dense dari Nol\nclass CustomDense(layers.Layer):\n    \"\"\"Reimplementasi Dense layer: output = activation(x @ W + b)\"\"\"\n    def __init__(self, units, activation=None, **kwargs):\n        super().__init__(**kwargs)\n        self.units      = units\n        self.activation = keras.activations.get(activation)\n\n    def build(self, input_shape):\n        self.W = self.add_weight(\n            name='kernel', shape=(input_shape[-1], self.units),\n            initializer='glorot_uniform', trainable=True)\n        self.b = self.add_weight(\n            name='bias', shape=(self.units,),\n            initializer='zeros', trainable=True)\n        super().build(input_shape)\n\n    def call(self, inputs):\n        out = tf.matmul(inputs, self.W) + self.b\n        return self.activation(out) if self.activation else out\n\n    def get_config(self):\n        cfg = super().get_config()\n        cfg.update({'units': self.units,\n                    'activation': keras.activations.serialize(self.activation)})\n        return cfg\n\nprint('CustomDense OK')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T04:16:08.158271Z","iopub.execute_input":"2026-06-02T04:16:08.158606Z","iopub.status.idle":"2026-06-02T04:16:08.167890Z","shell.execute_reply.started":"2026-06-02T04:16:08.158580Z","shell.execute_reply":"2026-06-02T04:16:08.166993Z"}},"outputs":[{"name":"stdout","text":"CustomDense OK\n","output_type":"stream"}],"execution_count":14},{"id":"5e5fc3e2-3555-4c66-addc-5dda521ae5f6","cell_type":"code","source":"# Custom Layer 2 : Multi-Head Attention dari Nol\nclass CustomMultiHeadAttention(layers.Layer):\n    \"\"\"Scaled Dot-Product Multi-Head Attention reimplementasi dari nol.\"\"\"\n    def __init__(self, num_heads, key_dim, **kwargs):\n        super().__init__(**kwargs)\n        self.num_heads = num_heads\n        self.key_dim   = key_dim\n        self.d_model   = num_heads * key_dim\n\n    def build(self, input_shape):\n        d = self.d_model\n        self.Wq = self.add_weight(name='Wq', shape=(input_shape[-1], d), initializer='glorot_uniform')\n        self.Wk = self.add_weight(name='Wk', shape=(input_shape[-1], d), initializer='glorot_uniform')\n        self.Wv = self.add_weight(name='Wv', shape=(input_shape[-1], d), initializer='glorot_uniform')\n        self.Wo = self.add_weight(name='Wo', shape=(d, input_shape[-1]), initializer='glorot_uniform')\n        super().build(input_shape)\n\n    def split_heads(self, x, batch_size):\n        x = tf.reshape(x, (batch_size, -1, self.num_heads, self.key_dim))\n        return tf.transpose(x, perm=[0, 2, 1, 3])\n\n    def call(self, query, value=None, key=None):\n        if value is None: value = query\n        if key   is None: key   = query\n        bs = tf.shape(query)[0]\n\n        Q = self.split_heads(tf.matmul(query, self.Wq), bs)\n        K = self.split_heads(tf.matmul(key,   self.Wk), bs)\n        V = self.split_heads(tf.matmul(value, self.Wv), bs)\n\n        scale   = tf.cast(tf.math.sqrt(float(self.key_dim)), tf.float32)\n        scores  = tf.matmul(Q, K, transpose_b=True) / scale\n        weights = tf.nn.softmax(scores, axis=-1)\n        context = tf.matmul(weights, V)\n\n        context = tf.transpose(context, perm=[0, 2, 1, 3])\n        context = tf.reshape(context, (bs, -1, self.d_model))\n        return tf.matmul(context, self.Wo)\n\n    def get_config(self):\n        cfg = super().get_config()\n        cfg.update({'num_heads': self.num_heads, 'key_dim': self.key_dim})\n        return cfg\n\nprint('CustomMultiHeadAttention OK')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T04:16:08.169057Z","iopub.execute_input":"2026-06-02T04:16:08.169402Z","iopub.status.idle":"2026-06-02T04:16:08.187599Z","shell.execute_reply.started":"2026-06-02T04:16:08.169381Z","shell.execute_reply":"2026-06-02T04:16:08.186883Z"}},"outputs":[{"name":"stdout","text":"CustomMultiHeadAttention OK\n","output_type":"stream"}],"execution_count":15},{"id":"23ac3453-c83d-40d4-97c8-1c137bb88e15","cell_type":"code","source":"# Custom Layer 3 : Dropout dari Nol\nclass CustomDropout(layers.Layer):\n    \"\"\"Reimplementasi Dropout layer.\"\"\"\n    def __init__(self, rate, **kwargs):\n        super().__init__(**kwargs)\n        self.rate = rate\n\n    def call(self, inputs, training=None):\n        if training:\n            return tf.nn.dropout(inputs, rate=self.rate)\n        return inputs\n\n    def get_config(self):\n        cfg = super().get_config()\n        cfg.update({'rate': self.rate})\n        return cfg\n\n\n# Custom Layer 4 : Layer Normalization dari Nol\nclass CustomLayerNorm(layers.Layer):\n    \"\"\"Reimplementasi Layer Normalization.\"\"\"\n    def __init__(self, eps=1e-6, **kwargs):\n        super().__init__(**kwargs)\n        self.eps = eps\n\n    def build(self, input_shape):\n        self.gamma = self.add_weight(\n            name='gamma', shape=input_shape[-1:], initializer='ones')\n        self.beta = self.add_weight(\n            name='beta', shape=input_shape[-1:], initializer='zeros')\n        super().build(input_shape)\n\n    def call(self, inputs):\n        mean, var = tf.nn.moments(inputs, axes=[-1], keepdims=True)\n        return self.gamma * (inputs - mean) / tf.sqrt(var + self.eps) + self.beta\n\n    def get_config(self):\n        cfg = super().get_config()\n        cfg.update({'eps': self.eps})\n        return cfg\n\nprint('CustomDropout & CustomLayerNorm OK')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T04:16:08.188555Z","iopub.execute_input":"2026-06-02T04:16:08.188997Z","iopub.status.idle":"2026-06-02T04:16:08.206038Z","shell.execute_reply.started":"2026-06-02T04:16:08.188975Z","shell.execute_reply":"2026-06-02T04:16:08.205221Z"}},"outputs":[{"name":"stdout","text":"CustomDropout & CustomLayerNorm OK\n","output_type":"stream"}],"execution_count":16},{"id":"c4a46de7-dea2-41ba-8ca1-90608d810fc2","cell_type":"markdown","source":"## 8. Model Baseline LSTM (Functional API)","metadata":{}},{"id":"5e9615d3-7b08-4dfb-aeb4-407d974bb28d","cell_type":"markdown","source":"Model Baseline LSTM dibangun dengan Functional API, menggunakan `CustomDense`, `CustomDropout`, `CustomLayerNorm`, dan `CustomMultiHeadAttention`.","metadata":{}},{"id":"6c2385e7-92d0-4ff6-8de6-c086372f1016","cell_type":"code","source":"def build_baseline_lstm(window_size, n_features, horizon):\n    inp = keras.Input(shape=(window_size, n_features), name='input')\n\n    # LSTM stack\n    x = layers.LSTM(128, return_sequences=True, name='lstm_1')(inp)\n    x = CustomDropout(0.2, name='drop_1')(x)\n    x = CustomLayerNorm(name='norm_1')(x)\n\n    x = layers.LSTM(64, return_sequences=True, name='lstm_2')(x)\n    x = CustomDropout(0.2, name='drop_2')(x)\n\n    # Custom Multi-Head Attention\n    attn = CustomMultiHeadAttention(num_heads=4, key_dim=16, name='mha')(x)\n    x    = 