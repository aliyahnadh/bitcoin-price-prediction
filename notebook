asikan dalam line chart prediksi vs aktual + tabel perbandingan dengan kolom selisih.","metadata":{}},{"id":"6b056120-f788-4988-b02c-0fcdcbf73bdd","cell_type":"code","source":"# Fungsi inverse transform (khusus kolom Close)\ndef inverse_close(scaled_values):\n    flat  = scaled_values.ravel()\n    dummy = np.zeros((len(flat), N_FEATURES))\n    dummy[:, TARGET_IDX] = flat\n    inv = scaler.inverse_transform(dummy)[:, TARGET_IDX]\n    return inv.reshape(scaled_values.shape)\n\n\n# Inferensi Baseline LSTM\npred_baseline = []\nfor bx, _ in test_ds:\n    pred_baseline.append(baseline_lstm(bx, training=False).numpy())\npred_baseline = np.vstack(pred_baseline)   # (N_test, HORIZON)\n\n\n# Inferensi Seq2Seq — Autoregressive\ndef autoregressive_inference(model, X_test, horizon):\n    \"\"\"\n    Autoregressive decoding untuk Seq2Seq:\n    - Posisi 0 decoder = BOS token (0)\n    - Setiap step menggunakan prediksi step sebelumnya\n    \"\"\"\n    all_preds = []\n    for i in range(len(X_test)):\n        enc_in     = X_test[i:i+1]   # (1, window, features)\n        step_preds = []\n\n        for step in range(horizon):\n            # Bangun decoder input dari prediksi yang sudah ada\n            dec_full = np.zeros((1, horizon, 1), dtype=np.float32)\n            for s, p in enumerate(step_preds):\n                dec_full[0, s + 1, 0] = p   # geser 1 (posisi 0 = BOS tetap 0)\n\n            out  = model((enc_in, dec_full), training=False).numpy()\n            step_preds.append(float(out[0, step]))\n\n        all_preds.append(step_preds)\n\n    return np.array(all_preds, dtype=np.float32)\n\nprint('Menjalankan autoregressive inference untuk Seq2Seq...')\npred_seq2seq = autoregressive_inference(seq2seq, X_test, HORIZON)\nprint(f'Baseline shape : {pred_baseline.shape}')\nprint(f'Seq2Seq shape  : {pred_seq2seq.shape}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T05:42:37.873840Z","iopub.execute_input":"2026-06-02T05:42:37.874185Z","iopub.status.idle":"20