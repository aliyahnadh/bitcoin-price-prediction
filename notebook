xt/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n</pre>\n"},"metadata":{}}],"execution_count":17},{"id":"a6eb4006-6c76-4009-b703-4e208e5b9abd","cell_type":"markdown","source":"## 9. Model Seq2Seq LSTM (Model Subclassing + Teacher Forcing)","metadata":{}},{"id":"ae491f63-609f-4eb6-9d44-cef6542b8b7d","cell_type":"markdown","source":"\n* Seq2Seq LSTM dengan Teacher Forcing dibangun menggunakan Functional API (`build_seq2seq_functional`).\n* Seq2Seq LSTM juga dibangun ulang via Model Subclassing (`class Seq2SeqLSTM`).\n","metadata":{}},{"id":"75504bc0-696b-4f0b-a87c-2009a479a413","cell_type":"code","source":"# Seq2Seq LSTM — Functional API (Teacher Forcing)\ndef build_seq2seq_functional(window_size, n_features, horizon, lstm_units=128):\n    # Encoder\n    enc_input = keras.Input(shape=(window_size, n_features), name='enc_input')\n    x = layers.LSTM(lstm_units, return_sequences=True, name='enc_lstm1')(enc_input)\n    x = CustomDropout(0.2, name='enc_drop')(x)\n    x = CustomLayerNorm(name='enc_norm')(x)\n    _, enc_h, enc_c = layers.LSTM(lstm_units, return_state=True, name='enc_lstm2')(x)\n\n    # Decoder\n    dec_input = keras.Input(shape=(horizon, 1), name='dec_input')\n    x = layers.LSTM(lstm_units, return_sequences=True, name='dec_lstm')(\n        dec_input, initial_state=[enc_h, enc_c]\n    )\n    x = CustomDropout(0.2, name='dec_drop')(x)\n    attn = CustomMultiHeadAttention(num_heads=4, key_dim=16, name='dec_mha')(x)\n    x = layers.Add(name='dec_add')([x, attn])\n    x = CustomLayerNorm(name='dec_norm')(x)\n    x = CustomDense(64, activation='relu', name='dec_proj')(x)\n    x = CustomDense(1, activation='linear', name='dec_out')(x)\n    output = layers.Reshape((horizon,), name='reshape')(x)\n\n    return keras.Model(inputs=[enc_input, dec_input], outputs=output, name='Seq2Seq_Functional')\n\nseq2seq_functional = build_seq2seq_functional(WINDOW_SIZE, N_FEATURES, HORIZON)\nseq2seq_functional.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-02T07:01:11.236568Z","iopub.execute_input":"2026-06-02T07:01:11.237304Z","iopub.status.idle":"2026-06-02T07:01:11.422315Z","shell.execute_reply.started":"2026-06-02T07:01:11.237272Z","shell.execute_reply":"2026-06-02T07:01:11.421545Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"Seq2Seq_Functional\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"Seq2Seq_Functional\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mConnected to     \u001b[0m\u001b[1m \u001b[0m┃\n┡━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━┩\n│ enc_input           │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m48\u001b[0m, \u001b[38;5;34m10\u001b[0m)    │          \u001b[38;5;34m0\u001b[0m │ -                 │\n│ (\u001b[38;5;33mInputLayer\u001b[0m)        │                   │            │                   │\n├─────────────────────┼───────────────────┼────────────┼───────────────────┤\n│ enc_lstm1 (\u001b[38;5;33mLSTM\u001b[0m)    │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m48\u001b[0m, \u001b[38;5;34m128\u001b[0m)   │     \u001b[38;5;34m71,168\u001b[0m │ enc_input[\u001b[38;5;34m0\u001b[0m][\u001b[38;5;34m0\u001b[0m]   │\n├─────────────────────┼───────────────────┼─────